{
  "name": "firecrawl credential read-only probe",
  "env": {
    "required": ["FIRECRAWL_API_KEY"]
  },
  "checks": [
    {
      "expect_json_path": "data",
      "expect_status": 200,
      "headers": {
        "Authorization": "Bearer ${FIRECRAWL_API_KEY}"
      },
      "method": "GET",
      "name": "team activity readable",
      "read_only": true,
      "type": "http_json",
      "url": "https://api.firecrawl.dev/v2/team/activity?limit=1"
    }
  ]
}
